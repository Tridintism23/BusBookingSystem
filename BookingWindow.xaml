<Window x:Class="BusBookingSystem.BookingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BusBookingSystem"
        mc:Ignorable="d"
        Title="BookingWindow" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <DataGrid x:Name="dgBookings" 
                  Grid.Column="0" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True"
                  SelectionChanged="dgBookings_SelectionChanged"
                  Margin="0,0,10,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Booking ID" Binding="{Binding BookingId}" Width="90"/>
                <DataGridTextColumn Header="Customer Code" Binding="{Binding Ccode}" Width="100"/>
                <DataGridTextColumn Header="Bus ID" Binding="{Binding BusId}" Width="80"/>
                <DataGridTextColumn Header="Seats" Binding="{Binding SeatsBooked}" Width="60"/>
                <DataGridTextColumn Header="Booking Date" Binding="{Binding BookingDate, StringFormat={}{0:dd/MM/yyyy HH:mm}}" Width="120"/>
                <DataGridTextColumn Header="Total Amount" Binding="{Binding TotalAmount, StringFormat={}{0:N0}}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Column="1">


            <StackPanel>
                <TextBlock Text="Booking search:" VerticalAlignment="Center" Margin="0 5 0 5"/>
                <TextBox x:Name="txtSearch" Grid.Column="1" Margin="0 5 0 5" VerticalAlignment="Center"/>
                <Button Content="Search" Click="btnSearch_Click" Margin="0 5 0 5" Padding="10,2"/>
            </StackPanel>

            <Grid Margin="0,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Booking ID" VerticalAlignment="Center"/>
                <TextBox x:Name="txtBookingId" Grid.Column="1"/>
            </Grid>

            <!-- CHỌN KHÁCH HÀNG TỪ COMBOBOX -->
            <Grid Margin="0,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Customer" VerticalAlignment="Center"/>
                <ComboBox x:Name="cbCustomers" Grid.Column="1" DisplayMemberPath="DisplayInfo" SelectedValuePath="ccode"/>
            </Grid>

            <!-- CHỌN CHUYẾN XE TỪ COMBOBOX -->
            <Grid Margin="0,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Bus / Route" VerticalAlignment="Center"/>
                <ComboBox x:Name="cbBuses" Grid.Column="1" DisplayMemberPath="DisplayInfo" SelectedValuePath="BusId"/>
            </Grid>

            <Grid Margin="0,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Seats booked" VerticalAlignment="Center"/>
                <TextBox x:Name="txtSeatsBooked" Grid.Column="1" Text="1"/>
            </Grid>

            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Total amount" VerticalAlignment="Center"/>
                <TextBox x:Name="txtTotalAmount" Grid.Column="1" Text="" IsReadOnly="True"/>
            </Grid>

            <Button Content="Add new booking" Click="btnAddBooking_Click" Margin="0,0,0,5" Padding="5"/>
            <Button Content="Delete selected booking" Click="btnDeleteBooking_Click" Margin="0,0,0,5" Padding="5"/>
            <Button Content="Read from file" Click="btnReadFile_Click" Margin="0,0,0,5" Padding="5"/>
            <Button Content="Write to file" Click="btnWriteFile_Click" Margin="0,0,0,5" Padding="5"/>

        </StackPanel>
    </Grid>
</Window>
