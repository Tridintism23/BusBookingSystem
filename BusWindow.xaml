<Window x:Class="BusBookingSystem.BusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BusBookingSystem"
        mc:Ignorable="d"
        Title="BusWindow" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>
        
        <DataGrid x:Name="dgBuses" 
                  Grid.Column="0" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True"
                  SelectionChanged="dgBuses_SelectionChanged"
                  Margin="0,0,10,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Bus ID" Binding="{Binding BusId}" Width="75"/>
                <DataGridTextColumn Header="Bus number" Binding="{Binding BusNumber}" Width="95"/>
                <DataGridTextColumn Header="Departure" Binding="{Binding Departure}" Width="90"/>
                <DataGridTextColumn Header="Destination" Binding="{Binding Destination}" Width="90"/>
                <DataGridTextColumn Header="Time" Binding="{Binding DepartureTime}" Width="75"/>
                <DataGridTextColumn Header="Total Seats" Binding="{Binding TotalSeats}" Width="75"/>
                <DataGridTextColumn Header="Available" Binding="{Binding AvailableSeats}" Width="70"/>
                <DataGridTextColumn Header="Price" Binding="{Binding TicketPrice, StringFormat={}{0:N0}}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Column="1">
            <StackPanel>
                <TextBlock Text="Search by Departure or Destination:" VerticalAlignment="Center" Margin="0 5 0 5"/>
                <TextBox x:Name="txtSearch" Grid.Column="1" Margin="0 5 0 5" VerticalAlignment="Center"/>
                <Button Content="Search" Click="btnSearch_Click" Margin="0 5 0 5" Padding="10,2"/>
            </StackPanel>

            <Grid Margin="0,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Bus ID" VerticalAlignment="Center"/>
                <TextBox x:Name="txtBusId" Grid.Column="1"/>
            </Grid>

            <Grid Margin="0,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Bus number" VerticalAlignment="Center"/>
                <TextBox x:Name="txtBusNumber" Grid.Column="1"/>
            </Grid>

            <Grid Margin="0,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Departure" VerticalAlignment="Center"/>
                <TextBox x:Name="txtDeparture" Grid.Column="1"/>
            </Grid>

            <Grid Margin="0,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Destination" VerticalAlignment="Center"/>
                <TextBox x:Name="txtDestination" Grid.Column="1"/>
            </Grid>

            <Grid Margin="0,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Departure time" VerticalAlignment="Center"/>
                <TextBox x:Name="txtDepartureTime" Grid.Column="1"/>
            </Grid>

            <Grid Margin="0,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Total seats" VerticalAlignment="Center"/>
                <TextBox x:Name="txtTotalSeats" Grid.Column="1" Text="40"/>
            </Grid>

            <Grid Margin="0,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Available seats" VerticalAlignment="Center"/>
                <TextBox x:Name="txtAvailableSeats" Grid.Column="1" Text="40"/>
            </Grid>

            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Ticket price" VerticalAlignment="Center"/>
                <TextBox x:Name="txtTicketPrice" Grid.Column="1" Text="150000"/>
            </Grid>

            <Button Content="Add new bus" Click="btnAddBus_Click" Margin="0,0,0,5" Padding="5"/>
            <Button Content="Delete selected bus" Click="btnDeleteBus_Click" Margin="0,0,0,5" Padding="5"/>
            <Button Content="Read from file" Click="btnReadFile_Click" Margin="0,0,0,5" Padding="5"/>
            <Button Content="Write to file" Click="btnWriteFile_Click" Margin="0,0,0,5" Padding="5"/>

        </StackPanel>
    </Grid>
</Window>
